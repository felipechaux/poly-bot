# ============================================================
# Polymarket Bot — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# --- Trading Mode ---
# "paper" = simulate trades against live order books (safe, default)
# "live"  = real trades with real money (requires ENABLE_LIVE_TRADING=true)
POLY_MODE=paper

# Guard rail: must explicitly set to "true" to enable live trading
ENABLE_LIVE_TRADING=false

# --- Wallet (only needed for live trading) ---
# Your Ethereum private key (hex, with or without 0x prefix)
POLY_PRIVATE_KEY=

# Polygon chain ID: 137 = mainnet, 80002 = Amoy testnet
POLY_CHAIN_ID=137

# --- Paper Trading ---
POLY_PAPER_INITIAL_BALANCE=10000.0

# --- API ---
POLY_CLOB_HOST=https://clob.polymarket.com
POLY_GAMMA_HOST=https://gamma-api.polymarket.com

# --- Observability ---
# Optional: OTLP endpoint for OpenTelemetry metrics/traces
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- Logging ---
# "json" for production, "console" for development
LOG_FORMAT=console
LOG_LEVEL=INFO
